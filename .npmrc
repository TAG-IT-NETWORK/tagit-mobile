# Flatten node_modules so React Native autolinking + Expo SDK can discover
# native modules using npm-style resolution. pnpm's default symlinked layout
# breaks the Android `generateAutolinkingPackageList` task — it emits stale
# `expo.core.ExpoModulesPackage` imports, which then fail to compile.
# Scoped to this app only; the rest of the monorepo keeps pnpm's default linker.
node-linker=hoisted
shamefully-hoist=true
