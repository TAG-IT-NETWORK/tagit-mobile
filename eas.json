{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tagit-services-31154571939.us-central1.run.app",
        "EXPO_PUBLIC_API_KEY": "tagit-hack-2026-key",
        "EXPO_PUBLIC_VERIFIER_URL": "https://verify.tagit.network"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tagit-services-31154571939.us-central1.run.app",
        "EXPO_PUBLIC_API_KEY": "tagit-hack-2026-key",
        "EXPO_PUBLIC_VERIFIER_URL": "https://verify.tagit.network"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://tagit-services-31154571939.us-central1.run.app",
        "EXPO_PUBLIC_API_KEY": "tagit-hack-2026-key",
        "EXPO_PUBLIC_VERIFIER_URL": "https://verify.tagit.network"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "info@tagit.network",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_10CHAR_TEAM_ID"
      }
    }
  }
}
