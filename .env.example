# ORACULAR Mobile — v1 customer app config.
# Copy to .env (gitignored). All EXPO_PUBLIC_* values are baked into the build.

# Backend (live Cloud Run instance)
EXPO_PUBLIC_API_URL=https://tagit-services-31154571939.us-central1.run.app
EXPO_PUBLIC_API_KEY=

# Optional — keyed/faster Base Sepolia RPC for direct reads (default: public)
EXPO_PUBLIC_BASE_SEPOLIA_RPC=

# Dev/demo only: query a known holder so the Vault is populated immediately.
# A fresh embedded wallet owns nothing; this lets you SEE assets right after
# onboarding. Holds ~20 of the 26 seeded TAGITCore tokens on Base Sepolia.
# Remove for a real user build.
EXPO_PUBLIC_DEV_OWNER=0x1804c8AB1F12E6bbf3894d4083f33e07309d1f38

# Feature flags (default off; enable once external infra is in place)
EXPO_PUBLIC_ENABLE_AA=false
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=
